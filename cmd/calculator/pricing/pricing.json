  "api_descriptions": {
    "geocoding": {
      "name": "Geocoding",
      "description": "Converts addresses to coordinates and vice versa. Used for location search, address validation, and mapping user input to map coordinates."
    },
    "routing": {
      "name": "Routing",
      "description": "Calculates optimal routes and directions between locations. Essential for navigation, delivery optimization, and turn-by-turn guidance."
    },
    "map_tiles_raster": {
      "name": "Map Tiles Raster",
      "description": "Pre-rendered image tiles for displaying maps. Used for web and mobile map visualization with static map backgrounds."
    },
    "map_tiles_vector_2d": {
      "name": "Map Tiles Vector 2D",
      "description": "Scalable vector-based tiles for 2D map rendering. Offers better performance and styling flexibility compared to raster tiles."
    },
    "map_tiles_vector_3d": {
      "name": "Map Tiles Vector 3D",
      "description": "Photorealistic 3D map tiles with elevation data. Provides immersive 3D map experiences and terrain visualization."
    },
    "static_maps": {
      "name": "Static Maps",
      "description": "Pre-rendered static map images. Useful for generating map images for emails, documents, and situations where interactive maps aren't needed."
    },
    "dynamic_maps": {
      "name": "Dynamic Maps",
      "description": "Interactive web map loads (e.g. Mapbox GL JS, Google Dynamic Maps). Billed per map load; supports real-time styling and full client-side interactivity. Use for embedded interactive maps on websites and apps.",
      "notes": "Includes Map Loads for Web / Dynamic Maps SKUs (Mapbox GL JS, Google Dynamic Maps)."
    },
    "static_street_view": {
      "name": "Street View",
      "description": "Street-level panoramic imagery for visualization of locations. Great for property listings, travel apps, and street exploration."
    },
    "distance_matrix": {
      "name": "Distance Matrix",
      "description": "Calculates distances and travel times between multiple origin and destination pairs. Essential for logistics, delivery routing, and journey planning."
    },
    "elevation": {
      "name": "Elevation",
      "description": "Retrieves elevation data for specific locations. Used for terrain analysis, hiking apps, construction planning, and weather applications."
    },
    "aerial_view": {
      "name": "Aerial View",
      "description": "High-resolution aerial and satellite imagery. Ideal for real estate, urban planning, environmental monitoring, and detailed location analysis."
    }
  },
